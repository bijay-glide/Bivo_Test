# Copy to `.env` and fill in real values: `cp .env.example .env`
# Never commit `.env`.

# --- URLs ---
# UI host selection for Playwright browser navigation.
# - Set UI_ENV=dev to run against dev FE
# - Set UI_ENV=local to run against local FE (http://localhost:8080)
UI_ENV=dev
UI_BASE_URL_DEV=https://bivo-dev.bivotech.co
UI_BASE_URL_LOCAL=http://localhost:8080
# Optional explicit override (highest priority)
# UI_BASE_URL=

# Backend host used by helper API calls (OTP, internal identity, etc.)
HOST=https://devapi.bivotech.co

# REST API base (API tests + apiRequest) — can differ from HOST
API_BASE_URL=https://devapi.bivotech.co

# --- API ---
TENANT_IDENTIFIER=your-tenant-id
API_USERNAME=your-api-username-or-client-id
API_PASSWORD=your-api-password-or-secret

# Optional: test data / tuning (used only if your workflow references them)
TEST_EMAIL_DOMAIN=@example.com
TEST_PHONE_PREFIX=715
DEBUG=false
API_TIMEOUT=30000

# --- Keycloak (OTP helper, admin flows) ---
KEYCLOAK_HOST=https://your-keycloak-host
KEYCLOAK_AUTH_URI=realms/master/protocol/openid-connect/token
KEYCLOAK_URI=admin
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=admin-cli
KEYCLOAK_USERNAME=your-keycloak-user
KEYCLOAK_PASSWORD=your-keycloak-password
KEYCLOAK_GRANT_TYPE=password

# --- Transaction service OAuth (wire / client-credentials) ---
TRANSACTION_CLIENT_ID=transaction-v1
TRANSACTION_CLIENT_SECRET=your-transaction-client-secret
TRANSACTION_GRANT_TYPE=client_credentials

# --- UI login shortcuts (parallel specs, manual login helper) ---
LOGIN_PHONE_RAW=15551234567
LOGIN_PASSWORD=YourUiTestPassword
FIRST_LOGIN_PASSWORD=YourUiTestPassword
STANDALONE_ACCOUNT=

# --- Parallel worker count (used by test:ui:userweb:full and test:ui:userweb:parallel-all) ---
# Onboarding (1.1–1.3) always runs on 1 worker regardless of this value.
UI_WORKERS=4
